# Supabase PostgreSQL connection string
DATABASE_URL=postgresql+psycopg2://postgres:[YOUR-PASSWORD]@[PROJECT-REF].supabase.co:5432/postgres

# Demo JWT secret
JWT_SECRET=change-me-in-demo
JWT_ALGORITHM=HS256
